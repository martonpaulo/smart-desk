# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.readonly

# Security
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-byte-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# PowerSync
NEXT_PUBLIC_POWERSYNC_URL=https://your-powersync-endpoint
# PowerSync auth source:
# - supabase: use Supabase access_token (requires Supabase Auth enabled in PowerSync)
# - development-token: always use NEXT_PUBLIC_POWERSYNC_TOKEN
NEXT_PUBLIC_POWERSYNC_AUTH_MODE=supabase
# Required when NEXT_PUBLIC_POWERSYNC_AUTH_MODE=development-token
NEXT_PUBLIC_POWERSYNC_TOKEN=your-powersync-development-token

# PowerSync CLI
PS_ADMIN_TOKEN=your-powersync-personal-access-token
PROJECT_ID=your-powersync-project-id
INSTANCE_ID=your-powersync-instance-id
# Optional: required only if your token has access to multiple organizations
ORG_ID=your-powersync-org-id

# Sync job security
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-secret

# Vercel (GitHub Actions)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
