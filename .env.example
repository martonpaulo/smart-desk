# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Google OAuth (Calendar)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.readonly

# Token/session security
OAUTH_STATE_SECRET=replace-with-a-long-random-secret
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-byte-key

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Public client-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# PowerSync (if your setup requires explicit endpoint/credentials)
POWERSYNC_URL=https://your-powersync-endpoint
POWERSYNC_API_KEY=your-powersync-api-key
NEXT_PUBLIC_POWERSYNC_URL=https://your-powersync-endpoint

# Sync job security
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-secret
